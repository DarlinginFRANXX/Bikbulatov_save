<Window x:Class="Bikbulatov_save.PriorChangeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Изменение приоритета" Height="150" Width="300" FontFamily="Century Gothic"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" Margin="10">
                <Label Content="Приоритет" FontSize="20"></Label>
                <TextBox Name="TBPriority" FontSize="20" Width="100"></TextBox>
            </StackPanel>
            <Button Name="ChangePrior" Content="Изменить приоритет" FontSize="20" Width="250"
                    Click="ChangePrior_Click"></Button>
        </StackPanel>
    </Grid>
</Window>