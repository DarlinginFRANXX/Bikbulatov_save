<Page x:Class="Galiev_Глазки_save.AgentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Galiev_Глазки_save"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Агенты" FontFamily="Century Gothic">

    <Page.Resources>
        <local:StringToImageConverter x:Key="StringToImageConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Поиск и фильтры -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
            <TextBox Name="TBSearch" FontSize="15" Width="250" Margin="5"
                     TextChanged="TBSearch_TextChanged"/>

            <ComboBox Name="CBSort" SelectionChanged="CBSort_SelectionChanged" FontSize="15" 
                      Width="300" Margin="5">
                <TextBlock>Без сортировки</TextBlock>
                <TextBlock>Наименование по возрастанию</TextBlock>
                <TextBlock>Наименование по убыванию</TextBlock>
                <TextBlock>Скидка по возрастанию</TextBlock>
                <TextBlock>Скидка по убыванию</TextBlock>
                <TextBlock>Приоритет по возрастанию</TextBlock>
                <TextBlock>Приоритет по убыванию</TextBlock>
            </ComboBox>

            <ComboBox Name="CBFilt" FontSize="15" Width="100" Margin="5"
                      SelectionChanged="CBFilt_SelectionChanged">
                <TextBlock>Все типы</TextBlock>
                <TextBlock>ЗАО</TextBlock>
                <TextBlock>МКК</TextBlock>
                <TextBlock>МФО</TextBlock>
                <TextBlock>ОАО</TextBlock>
                <TextBlock>ООО</TextBlock>
                <TextBlock>ПАО</TextBlock>
            </ComboBox>
        </StackPanel>

        <!-- Кнопки действий -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,5">
            <Button Content="Добавить агента" Name="AddAgentBtn" FontSize="15" 
                    Width="200" Click="AddAgentBtn_Click" Background="#B175EE" 
                    Height="30" Margin="5"/>
            <Button Content="Изменить приоритет" Name="ChangePriorityBtn" 
                    Width="180" FontSize="15" Click="ChangePriorityBtn_Click" 
                    Visibility="Hidden" Background="#B175EE" Height="30" Margin="5"/>
        </StackPanel>

        <!-- Список агентов -->
        <ListView Name="AgentListView" Grid.Row="2" Margin="10"
                  SelectionChanged="AgentListView_SelectionChanged">
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Редактировать" Click="MenuItem_Click"/>
                </ContextMenu>
            </ListView.ContextMenu>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="1" Margin="1" CornerRadius="5"
                            Background="{Binding FonStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="800"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <Image Grid.Column="0" Grid.RowSpan="4" Width="130" Stretch="Uniform"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"
                                   Source="{Binding Logo, Converter={StaticResource StringToImageConverter}}"/>
                            <Image Grid.Column="0" Grid.RowSpan="4" Width="130" Stretch="Uniform"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5">
                                <Image.Source>
                                    <Binding Path="Logo">
                                        <Binding.TargetNullValue>
                                            <ImageSource>
                                                res/picture.png
                                            </ImageSource>
                                        </Binding.TargetNullValue>
                                    </Binding>
                                </Image.Source>
                            </Image>
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="{Binding AgentType.Title}" FontSize="20"/>
                                <TextBlock Text=" | " FontSize="20"/>
                                <TextBlock Text="{Binding Title}" FontSize="20"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="{Binding SalesForYear}" FontSize="15"/>
                                <TextBlock Text=" продаж за год" FontSize="15"/>
                            </StackPanel>

                            <TextBlock Grid.Row="2" Grid.Column="1" 
                                       Text="{Binding Phone}" FontSize="15"/>

                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="Приоритетность: " FontSize="15"/>
                                <TextBlock Text="{Binding Priority}" FontSize="15"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Discount,StringFormat= скидка {0}%}" FontSize="20"></TextBlock>
                            </StackPanel>

                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Пагинация -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Name="LeftDirButton" Content="&lt;" Width="30" Height="30"
                    Click="LeftDirButton_Click" Background="#B175EE" Margin="5"/>
            <ListBox Name="PageListBox" FontSize="20" MouseUp="PageListBox_MouseUp"
                     Background="White" MinWidth="50" Height="30">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
            <Button Name="RightDirButton" Content="&gt;" Width="30" Height="30"
                    Click="RightDirButton_Click" Background="#B175EE" Margin="5"/>
        </StackPanel>
    </Grid>
</Page>